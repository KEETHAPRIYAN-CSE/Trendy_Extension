{
  "name": "efx-terminal",
  "displayName": "SFX Terminal - Sound Effects",
  "description": "Add trendy sound effects to VS Code terminal commands! Plays success/error sounds when commands complete.",
  "version": "0.0.3",
  "publisher": "KEETHAPRIYAN",
  "author": {
    "name": "KEETHAPRIYAN",
    "url": "https://github.com/KEETHAPRIYAN-CSE"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KEETHAPRIYAN-CSE/Trendy_Extension.git"
  },
  "homepage": "https://github.com/KEETHAPRIYAN-CSE/Trendy_Extension#readme",
  "bugs": {
    "url": "https://github.com/KEETHAPRIYAN-CSE/Trendy_Extension/issues"
  },
  "keywords": [
    "terminal",
    "sound",
    "audio",
    "effects",
    "productivity",
    "feedback"
  ],
  "license": "MIT",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sfx-terminal.enable",
        "title": "SFX: Enable Terminal Audio"
      },
      {
        "command": "sfx-terminal.disable",
        "title": "SFX: Disable Terminal Audio"
      },
      {
        "command": "sfx-terminal.testSuccess",
        "title": "SFX: Test Success Sound"
      },
      {
        "command": "sfx-terminal.testError",
        "title": "SFX: Test Error Sound"
      },
      {
        "command": "sfx-terminal.showAudioPanel",
        "title": "SFX: Show Audio Panel"
      }
    ],
    "configuration": {
      "title": "SFX Terminal",
      "properties": {
        "sfxTerminal.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable audio feedback for terminal commands"
        },
        "sfxTerminal.successSound": {
          "type": "string",
          "default": "",
          "description": "Path to custom success sound file"
        },
        "sfxTerminal.errorSound": {
          "type": "string",
          "default": "",
          "description": "Path to custom error sound file"
        },
        "sfxTerminal.volume": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "maximum": 100,
          "description": "Volume level (0-100)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.13",
    "@types/vscode": "^1.93.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
  
}